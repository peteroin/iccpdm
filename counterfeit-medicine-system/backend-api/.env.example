# MongoDB Atlas Configuration
# Get your connection string from: https://www.mongodb.com/cloud/atlas

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://medicine-admin:PASSWORD_HERE@medicine-detector.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database Name
MONGODB_DATABASE=medicine_db

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# Optional: Connection timeout (milliseconds)
MONGODB_TIMEOUT=5000
